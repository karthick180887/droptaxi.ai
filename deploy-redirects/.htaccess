# Apache / cPanel / shared hosting — 301 redirects
# Append these lines to your existing .htaccess at the document root.
# Requires mod_rewrite (enabled by default on most shared hosting).

<IfModule mod_rewrite.c>
  RewriteEngine On

  # Drop-taxi alt-form -> canonical (drop-taxi-X -> drop-taxi-in-X)
  RewriteRule ^drop-taxi-cuddalore\.html$       /drop-taxi-in-cuddalore.html       [R=301,L]
  RewriteRule ^drop-taxi-erode\.html$           /drop-taxi-in-erode.html           [R=301,L]
  RewriteRule ^drop-taxi-hyderabad\.html$       /drop-taxi-in-hyderabad.html       [R=301,L]
  RewriteRule ^drop-taxi-madurai\.html$         /drop-taxi-in-madurai.html         [R=301,L]
  RewriteRule ^drop-taxi-munnar\.html$          /drop-taxi-in-munnar.html          [R=301,L]
  RewriteRule ^drop-taxi-neyveli\.html$         /drop-taxi-in-neyveli.html         [R=301,L]
  RewriteRule ^drop-taxi-srirangam\.html$       /drop-taxi-in-srirangam.html       [R=301,L]
  RewriteRule ^drop-taxi-thanjavur\.html$       /drop-taxi-in-thanjavur.html       [R=301,L]
  RewriteRule ^drop-taxi-tirunelveli\.html$     /drop-taxi-in-tirunelveli.html     [R=301,L]
  RewriteRule ^drop-taxi-villupuram\.html$      /drop-taxi-in-villupuram.html      [R=301,L]
</IfModule>
