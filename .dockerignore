# Files NOT to send into the Docker build context.
# Keep build context small for speed + security.

# Git
.git
.gitignore
.gitattributes

# Build artifacts (regenerated inside the build stage)
.next
node_modules
out
build

# Editor / OS noise
.vscode
.idea
.DS_Store
Thumbs.db

# Local env files — secrets live in K8s Secrets, never bake into the image
.env
.env.*
!.env.example

# Documentation, SEO briefs, design assets (not needed at runtime)
docs/
reports/
scripts/

# Python tooling (cleaned up, but defensive)
*.py
*.pyc
__pycache__/
scripts/requirements.txt

# Test files (none today, defensive for tomorrow)
**/*.test.ts
**/*.test.tsx
**/*.spec.ts
**/*.spec.tsx
coverage/

# Logs
npm-debug.log*
yarn-debug.log*

# Netlify (being phased out, but exclude from image regardless)
netlify.toml

# Container / k8s configs — not part of the runtime image
Dockerfile
.dockerignore
k8s-deployment.yaml
droptaxi-ingress.yaml
